{
  "rules": {
    ".read": false,
    ".write": false,
    "requests": {
      ".read": true,
      ".indexOn": ["customerId", "technicianId", "status", "createdAt"],
      "$requestId": {
        ".read": true,
        ".write": "((auth != null) && ((!data.exists() && newData.child('customerId').val() == auth.uid) || (data.exists() && (data.child('customerId').val() == auth.uid || data.child('technicianId').val() == auth.uid || data.child('assignedTechnicianId').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('technicians').child(auth.uid).child('role').val() == 'admin' || root.child('customers').child(auth.uid).child('role').val() == 'admin'))) ) || (data.exists() && (newData.child('reviewedByRole').val() == 'admin' || newData.child('adminReviewStatus').val() == 'approved' || newData.child('adminReviewStatus').val() == 'declined'))"
      }
    },
    "users": {
      ".read": true,
      ".indexOn": ["email", "emailAddress", "email_address"],
      "$uid": {
        ".read": true,
        ".write": "auth != null && ($uid == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('technicians').child(auth.uid).child('role').val() == 'admin' || root.child('customers').child(auth.uid).child('role').val() == 'admin')",
        "addresses": {
          ".read": "auth != null && ($uid == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
          "$addressId": {
            ".read": "auth != null && ($uid == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
            ".write": "auth != null && ($uid == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')"
          }
        }
      }
    },
    "customers": {
      ".read": true,
      ".indexOn": ["email", "emailAddress", "email_address"],
      "$uid": {
        ".read": true,
        ".write": "auth != null && ($uid == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('technicians').child(auth.uid).child('role').val() == 'admin' || root.child('customers').child(auth.uid).child('role').val() == 'admin')",
        "addresses": {
          ".read": "auth != null && ($uid == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
          "$addressId": {
            ".read": "auth != null && ($uid == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')",
            ".write": "auth != null && ($uid == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin')"
          }
        }
      }
    },
    "technicians": {
      ".read": true,
      ".indexOn": ["email", "emailAddress", "email_address"],
      "$uid": {
        ".read": true,
        ".write": "auth != null && ($uid == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('technicians').child(auth.uid).child('role').val() == 'admin' || root.child('customers').child(auth.uid).child('role').val() == 'admin')"
      }
    },
    "chats": {
      "$requestId": {
        ".read": "auth != null && root.child('requests').child($requestId).exists() && (root.child('requests').child($requestId).child('status').val() == 'accepted' || root.child('requests').child($requestId).child('status').val() == 'confirmed' || root.child('requests').child($requestId).child('status').val() == 'in-progress' || root.child('requests').child($requestId).child('status').val() == 'ongoing') && (root.child('requests').child($requestId).child('customerId').val() == auth.uid || root.child('requests').child($requestId).child('assignedTechnicianId').val() == auth.uid || root.child('requests').child($requestId).child('technicianId').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('technicians').child(auth.uid).child('role').val() == 'admin' || root.child('customers').child(auth.uid).child('role').val() == 'admin')",
        "$messageId": {
          ".read": "auth != null && root.child('requests').child($requestId).exists() && (root.child('requests').child($requestId).child('status').val() == 'accepted' || root.child('requests').child($requestId).child('status').val() == 'confirmed' || root.child('requests').child($requestId).child('status').val() == 'in-progress' || root.child('requests').child($requestId).child('status').val() == 'ongoing') && (root.child('requests').child($requestId).child('customerId').val() == auth.uid || root.child('requests').child($requestId).child('assignedTechnicianId').val() == auth.uid || root.child('requests').child($requestId).child('technicianId').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('technicians').child(auth.uid).child('role').val() == 'admin' || root.child('customers').child(auth.uid).child('role').val() == 'admin')",
          ".write": "auth != null && root.child('requests').child($requestId).exists() && (root.child('requests').child($requestId).child('status').val() == 'accepted' || root.child('requests').child($requestId).child('status').val() == 'confirmed' || root.child('requests').child($requestId).child('status').val() == 'in-progress' || root.child('requests').child($requestId).child('status').val() == 'ongoing') && (root.child('requests').child($requestId).child('customerId').val() == auth.uid || root.child('requests').child($requestId).child('assignedTechnicianId').val() == auth.uid || root.child('requests').child($requestId).child('technicianId').val() == auth.uid || root.child('users').child(auth.uid).child('role').val() == 'admin' || root.child('technicians').child(auth.uid).child('role').val() == 'admin' || root.child('customers').child(auth.uid).child('role').val() == 'admin') && newData.child('text').isString() && newData.child('text').val().length > 0 && newData.child('text').val().length <= 500 && newData.child('senderUid').val() == auth.uid"
        }
      }
    },
    "sessionLogs": {
      "login": {
        "customers": {
          ".read": true,
          ".indexOn": ["createdAt", "uid", "sessionId"],
          "$logId": {
            ".read": true,
            ".write": "auth != null"
          }
        },
        "technicians": {
          ".read": true,
          ".indexOn": ["createdAt", "uid", "sessionId"],
          "$logId": {
            ".read": true,
            ".write": "auth != null"
          }
        },
        "admins": {
          ".read": true,
          ".indexOn": ["createdAt", "uid", "sessionId"],
          "$logId": {
            ".read": true,
            ".write": "auth != null"
          }
        }
      },
      "logout": {
        "customers": {
          ".read": true,
          ".indexOn": ["createdAt", "uid", "sessionId"],
          "$logId": {
            ".read": true,
            ".write": "auth != null"
          }
        },
        "technicians": {
          ".read": true,
          ".indexOn": ["createdAt", "uid", "sessionId"],
          "$logId": {
            ".read": true,
            ".write": "auth != null"
          }
        },
        "admins": {
          ".read": true,
          ".indexOn": ["createdAt", "uid", "sessionId"],
          "$logId": {
            ".read": true,
            ".write": "auth != null"
          }
        }
      }
    }
  }
}
